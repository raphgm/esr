rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Test Connection ---
    match /test/{docId} {
      allow read: if true;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    // --- Creator Content ---
    match /creator_content/{contentId} {
      allow read, write: if isSignedIn();
    }

    // --- Posts ---
    match /posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Courses ---
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Products ---
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Campaigns ---
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Tasks ---
    match /tasks/{taskId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Jobs ---
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Channels ---
    match /channels/{channelId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Peers ---
    match /peers/{peerId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Connections ---
    match /connections/{connectionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Peer Messages ---
    match /peer_messages/{messageId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Mentorship ---
    match /mentorship_registry/{mentorId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /mentorship_requests/{requestId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Sync Ledger ---
    match /sync_queue/{syncId} {
      allow read, write: if isSignedIn();
    }
    match /sync_conflicts/{conflictId} {
      allow read, write: if isSignedIn();
    }
  }
}
