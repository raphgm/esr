    "@google-cloud/talent": "^7.2.0",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.18.1",
    "canvas-confetti": "^1.9.4",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^10.13.2",
    "firebase-admin": "^14.1.0",
    "hls.js": "^1.6.16",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
