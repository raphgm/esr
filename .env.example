# .env.example
GEMINI_API_KEY=
APP_URL=https://estarrapp.com

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Firebase Admin (required for LinkedIn social login to mint Firebase sessions).
# Paste the full JSON contents of a Firebase service account key (Project Settings
# > Service Accounts > Generate new private key) as a single-line string.
FIREBASE_SERVICE_ACCOUNT_KEY=

# SMTP Configuration (Optional)
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# AWS Configuration (S3 for Videos)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
